<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>kasi.connect101</title>

<style>
    body {
        margin: 0;
        font-family: 'Arial', sans-serif;
        background: #000;
        color: #fff;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 50px;
        border-bottom: 1px solid #333;
    }

    header img {
        height: 60px;
    }

    nav a {
        color: white;
        text-decoration: none;
        margin: 0 15px;
        transition: 0.3s;
    }

    nav a:hover {
        color: #aaa;
    }

    .hero {
        text-align: center;
        padding: 100px 20px;
    }

    .hero h1 {
        font-size: 3em;
        letter-spacing: 3px;
    }

    .hero button {
        margin-top: 20px;
        padding: 12px 30px;
        background: white;
        color: black;
        border: none;
        cursor: pointer;
        transition: 0.3s;
    }

    .hero button:hover {
        background: #aaa;
    }

    .products {
        display: flex;
        justify-content: center;
        gap: 40px;
        padding: 60px 20px;
        flex-wrap: wrap;
    }

    .card {
        border: 1px solid #333;
        padding: 20px;
        width: 250px;
        text-align: center;
        transition: 0.3s;
    }

    .card:hover {
        transform: scale(1.05);
        border-color: white;
    }

    .card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
    }

    footer {
        text-align: center;
        padding: 20px;
        border-top: 1px solid #333;
    }
</style>
</head>
<body>

<header>
    <img src="logo.png" alt="kasi.connect101 logo">
    <nav>
        <a href="#">Home</a>
        <a href="#products">Products</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h1>kasi.connect101</h1>
    <p>Future Tech & Street Sneakers</p>
    <button onclick="scrollToProducts()">Explore</button>
</section>

<section id="products" class="products">

    <div class="card">
        <img src="https://via.placeholder.com/250x180" alt="Sneakers">
        <h3>Sneakers</h3>
        <p>Fresh streetwear styles</p>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/250x180" alt="Phones">
        <h3>Cellphones</h3>
        <p>Latest smart tech</p>
    </div>

</section>

<footer>
    <p>© 2026 kasi.connect101 | All rights reserved</p>
</footer>

<script>
function scrollToProducts() {
    document.getElementById("products").scrollIntoView({
        behavior: "smooth"
    });
}
</script>

</body>
</html>
